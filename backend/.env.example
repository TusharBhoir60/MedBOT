# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_TITLE="AarogyaAgent API"
APP_VERSION="0.1.0"

# Server Settings
HOST=0.0.0.0
PORT=8000

# Security Configuration
# Comma-separated list of allowed hostnames/origins
ALLOWED_HOSTS=localhost,127.0.0.1,api
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
MAX_REQUEST_SIZE=10485760  # 10 MB in bytes

# Database Configuration
# Async DSN is used by the FastAPI application
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/aarogya
# Sync DSN is used by Alembic migrations
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/aarogya

# Database Pool Configuration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# Observability Configuration
LOG_LEVEL=INFO
LOG_FORMAT=JSON  # JSON or CONSOLE
