APP_ENV=production
APP_DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:secure_password_here@db:5432/aarogya
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:secure_password_here@db:5432/aarogya

# Security
# MUST CHANGE in production
SECRET_KEY=generate-a-secure-random-256-bit-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_DEFAULT=100

# Allowed hosts (comma separated)
ALLOWED_HOSTS=api.example.com,www.example.com
ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=JSON
